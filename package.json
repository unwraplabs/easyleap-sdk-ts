{
  "name": "easyleap-sdk",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "demo",
    "lib"
  ],
  "scripts": {
    "build:sdk": "cd lib && pnpm build",
    "build:demo": "cd demo && pnpm build",
    "dev:demo": "cd demo && pnpm dev",
    "lint:demo": "cd demo && pnpm lint",
    "lint:fix:demo": "cd demo && pnpm lint:fix",
    "preview:demo": "cd demo && pnpm preview",
    "storybook:lib": "cd lib && pnpm storybook",
    "publish:lib": "cd lib && npm publish --tag beta"
  },
  "pnpm": {
    "overrides": {
      "viem": "^2.47.6"
    }
  }
}